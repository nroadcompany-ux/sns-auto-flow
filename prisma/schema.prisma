// SNS AUTO FLOW — Prisma Schema
// Local: SQLite (zero setup). 배포 시 provider="postgresql" + DATABASE_URL 변경.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// 생성된 콘텐츠 묶음 (1회 자동화 실행 = 1 Content)
model Content {
  id          String   @id @default(cuid())
  topic       String
  angle       String   @default("일반")
  sourceType  String   @default("MANUAL")
  tone        String   @default("friendly")
  channels    String   // JSON 배열 ["INSTAGRAM","THREADS",...]
  contentJson String   // IGeneratedContent 전체 JSON
  status      String   @default("draft") // draft | scheduled | published | failed
  scheduledAt DateTime?
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  posts       Post[]
}

/// 채널별 발행 결과
model Post {
  id          String   @id @default(cuid())
  contentId   String
  content     Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)
  channel     String
  title       String?
  body        String
  hashtags    String   @default("")
  status      String   @default("draft") // draft | published | failed | fallback
  errorMsg    String?
  publishedAt DateTime?
  createdAt   DateTime @default(now())
}

/// 관리자 진단 로그
model DiagnosticLog {
  id        String   @id @default(cuid())
  error     String
  analysis  String?
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now())
}
