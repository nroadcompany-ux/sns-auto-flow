// SNS FLOW AUTO — Prisma schema
// Local dev uses SQLite (zero external DB needed). Swap `provider` to
// "postgresql" + a real DATABASE_URL when moving to production.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// A generated SNS post moving through the draft → scheduled → published flow.
model Content {
  id          String    @id @default(cuid())
  topic       String
  title       String
  body        String
  hashtags    String    @default("") // comma-separated
  platform    String    @default("instagram") // instagram | threads | blog | x
  tone        String    @default("friendly")
  imageUrl    String?
  status      String    @default("draft") // draft | scheduled | published | failed
  scheduledAt DateTime?
  publishedAt DateTime?
  externalUrl String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

/// A generated / processed image asset (Storage page).
model Asset {
  id        String   @id @default(cuid())
  prompt    String
  url       String
  width     Int      @default(1080)
  height    Int      @default(1080)
  createdAt DateTime @default(now())
}

/// A connected SNS channel (Settings page).
model Account {
  id        String   @id @default(cuid())
  platform  String
  handle    String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}
