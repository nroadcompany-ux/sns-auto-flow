generator client {
  provider = "prisma-client-js"
}
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
model User {
  id        String    @id @default(cuid())
  email     String    @unique
  name      String?
  role      Role      @default(USER)
  createdAt DateTime  @default(now())
  contents  Content[]
  brand     Brand?
}
enum Role { USER ADMIN SUPER_ADMIN }
model Brand {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id])
  name        String
  logoUrl     String?
  color       String   @default("#111111")
  hashtags    String[]
  tone        String   @default("friendly")
  imageEngine String   @default("custom")
  canvaApiKey String?
  templateId  String?
}
model Content {
  id          String     @id @default(cuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id])
  topic       String
  sourceType  SourceType @default(MANUAL)
  sourceUrl   String?
  status      Status     @default(DRAFT)
  scheduledAt DateTime?
  publishedAt DateTime?
  createdAt   DateTime   @default(now())
  posts       Post[]
}
enum SourceType { MANUAL URL FILE DIVERSIFIED }
enum Status { DRAFT SCHEDULED PUBLISHING PUBLISHED FAILED }
model Post {
  id          String   @id @default(cuid())
  contentId   String
  content     Content  @relation(fields: [contentId], references: [id])
  channel     Channel
  title       String?
  body        String
  imageUrl    String?
  hashtags    String[]
  status      Status   @default(DRAFT)
  errorMsg    String?
  retryCount  Int      @default(0)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
}
enum Channel {
  BLOG_NAVER NEWS_HOMEPAGE INSTAGRAM THREADS
  KAKAO_CHANNEL DAANGN BAND FACEBOOK
  PAYPLAY_BLOG PAYPLAY_PRESS
}
model DiagnosticLog {
  id        String   @id @default(cuid())
  error     String
  stack     String?
  analysis  String?
  fixCode   String?
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now())
}
