// SNS AUTO FLOW — Prisma Schema
// 로컬: DATABASE_URL="file:./prisma/dev.db" (SQLite)
// 프로덕션: DATABASE_URL=postgresql://... (Supabase / Vercel Postgres)
// provider는 DATABASE_URL prefix로 자동 구분

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// 생성된 콘텐츠 묶음 (1회 자동화 실행 = 1 Content)
model Content {
  id           String    @id @default(cuid())
  topic        String
  angle        String    @default("일반")
  sourceType   String    @default("MANUAL")
  tone         String    @default("friendly")
  channels     String    // JSON 배열 ["INSTAGRAM","THREADS",...]
  contentJson  String    // IGeneratedContent 전체 JSON
  status       String    @default("draft")
  scheduledAt  DateTime?
  publishedAt  DateTime?
  createdAt    DateTime  @default(now())
  // 영상 자동화 필드
  type         String    @default("text")   // "text" | "video"
  mediaUrl     String?                       // 완성된 MP4 URL
  renderJobId  String?                       // Remotion Lambda 작업 ID
  renderStatus String?   @default("pending") // pending|rendering|done|failed
  posts        Post[]
}

/// 이미지 뱅크 — Midjourney 수동 업로드 + Flux 자동 생성 이미지 저장
model ImageBank {
  id        String   @id @default(cuid())
  url       String
  label     String
  gender    String   @default("female") // female | male
  situation String?  // POS | kiosk | tableorder | custom
  source    String   @default("flux")   // midjourney | flux
  prompt    String?
  createdAt DateTime @default(now())
}

/// 채널별 발행 결과
model Post {
  id          String    @id @default(cuid())
  contentId   String
  content     Content   @relation(fields: [contentId], references: [id], onDelete: Cascade)
  channel     String
  title       String?
  body        String
  hashtags    String    @default("")
  status      String    @default("draft")
  errorMsg    String?
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
}

/// 관리자 진단 로그
model DiagnosticLog {
  id        String   @id @default(cuid())
  error     String
  analysis  String?
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now())
}
